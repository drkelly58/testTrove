{
  "name": "testtrove/app",
  "description": "TestTrove — test case management API (shared-hosting friendly)",
  "type": "project",
  "require": {
    "php": "^8.1",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.7",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "suggest": {
    "ext-pdo_sqlite": "SQLite (DB_DRIVER=sqlite)",
    "ext-pdo_mysql": "MySQL / MariaDB (DB_DRIVER=mysql)",
    "ext-pdo_pgsql": "PostgreSQL (DB_DRIVER=pgsql)"
  }
}
