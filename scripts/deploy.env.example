# Copy to scripts/deploy.env (gitignored) and adjust for your hosts.
# Both deploy-to-staging.sh and promote-to-production.sh source this file.

# --- deploy-to-staging.sh (run from your dev machine) ---
# rsync destination: SSH "user@host:/absolute/path/to/app-root" or a local path.
# App root = parent of the web directory (contains src/, vendor/, .env, storage/).
DEPLOY_STAGING_TARGET="user@staging.example.com:/home/user/testtrove-staging"

# --- promote-to-production.sh (run on the staging server) ---
DEPLOY_STAGING_ROOT="/home/customer/www/staging.testtrove.lk638.us"
DEPLOY_PRODUCTION_ROOT="/home/customer/www/testtrove.lk638.us"

# Web-exposed directory name on the server (public/ in this repo; often public_html on shared hosting).
DEPLOY_WEB_DIR="public_html"

# Optional: extra rsync excludes (paths relative to app root), space-separated.
# DEPLOY_EXTRA_EXCLUDES=".user.ini php.ini"

# Set to 1 to print rsync changes without copying (or pass --dry-run to the scripts).
# DEPLOY_DRY_RUN=1

# Set to 1 to skip "composer install --no-dev" before pushing from dev.
# DEPLOY_SKIP_COMPOSER=1

# Set to 1 to skip "npm run build" before pushing from dev.
# DEPLOY_SKIP_BUILD=1

# --- Email notifications (optional; configure on each server, not in this file) ---
# Deploy scripts never upload or overwrite .env on staging/production. To enable run
# notification email, edit .env on each host (see .env.example and README § Email notifications).
#
# Minimum on the server .env:
#   MAIL_ENABLED=1
#   MAIL_FROM="TestTrove <noreply@your-domain.com>"
#   APP_BASE_URL=https://your-domain.com
#
# PHP mail() on the host:
#   MAIL_TRANSPORT=php
#
# Or SMTP (typical on shared hosting):
#   MAIL_TRANSPORT=smtp
#   MAIL_SMTP_HOST=smtp.example.com
#   MAIL_SMTP_PORT=587
#   MAIL_SMTP_USER=
#   MAIL_SMTP_PASSWORD=
#   MAIL_SMTP_ENCRYPTION=tls
#
# After deploy, signed-in users opt in via Preferences → Email notifications.
